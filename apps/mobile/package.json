{
  "name": "hermes-mobile-control",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test": "npm run test:unit",
    "verify": "npm run typecheck && npm run test:unit && npx expo config --type public"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.12",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.19",
    "expo-secure-store": "~15.0.8",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2",
    "vitest": "^4.1.10"
  }
}
