# Copy to /etc/hermes-mobile-control/control-api.env on the Proxmox LXC.
# Own it by root:hermes (or root:root) and chmod 0640.

# Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
CONTROL_API_TOKEN=replace-with-generated-token

# Hermes-native projects and folders. Project selection is resolved server-side;
# it never changes Hermes' global active project.
CONTROL_API_HERMES_HOME=/home/hermes/.hermes
# Comma-separated roots permitted for project folder selection.
CONTROL_API_PROJECT_ROOTS=/home/hermes/repos

# Persist task state/events across service restarts.
CONTROL_API_DB_PATH=/var/lib/hermes-mobile-control/control-api.db
CONTROL_API_MAX_CONCURRENT_TASKS=4
# Mark a heartbeat-confirmed, output-quiet task as attention_required after this
# interval. It remains running and can recover when output resumes.
CONTROL_API_TASK_STALL_SECONDS=600
CONTROL_API_RATE_LIMIT_PER_MINUTE=60

# Preferred structured Hermes Control Extension bridge.
# The plugin and Control API should share this socket path and token.
# Install and enable deploy/hermes-control-bridge.service. The bridge service and
# Control API must use this same socket and token.
# CONTROL_API_HERMES_PLUGIN_SOCKET=/run/hermes/control-extension.sock
# CONTROL_API_HERMES_PLUGIN_TOKEN=replace-with-local-bridge-token
# HERMES_CONTROL_EXTENSION_SOCKET=/run/hermes/control-extension.sock
# HERMES_CONTROL_EXTENSION_TOKEN=replace-with-local-bridge-token
# HERMES_CONTROL_EXTENSION_MAX_CONCURRENT_TASKS=4
# HERMES_CONTROL_EXTENSION_HEARTBEAT_SECONDS=15
# Optional hard cap for operator policy. Leave unset: healthy long tasks are
# supervised by bridge/process heartbeats rather than a fixed 15-minute limit.
# HERMES_CONTROL_EXTENSION_HARD_TIMEOUT_SECONDS=86400
# HERMES_CONTROL_EXTENSION_PROCESS_HEARTBEAT_SECONDS=15

# Compatibility fallback when the structured extension bridge is unavailable.
# Use `command -v hermes` on the LXC and prefer the absolute path in production.
CONTROL_API_HERMES_COMMAND="/usr/local/bin/hermes chat -q"

# Optional: Discord webhook notifications for approval requests and terminal task states.
# CONTROL_API_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/[REDACTED]
