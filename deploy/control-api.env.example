# Copy to /etc/hermes-mobile-control/control-api.env on the Proxmox LXC.
# Own it by root:hermes (or root:root) and chmod 0640.

# Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
CONTROL_API_TOKEN=replace-with-generated-token

# Persist task state/events across service restarts.
CONTROL_API_DB_PATH=/var/lib/hermes-mobile-control/control-api.db

# Preferred structured Hermes Control Extension bridge.
# The extension and Control API are normally supervised as separate processes.
# CONTROL_API_HERMES_PLUGIN_SOCKET=/run/hermes/control-extension.sock

# Compatibility fallback when the structured extension bridge is unavailable.
# Use `command -v hermes` on the LXC and prefer the absolute path in production.
CONTROL_API_HERMES_COMMAND="/usr/local/bin/hermes chat -q"

# Optional: Discord webhook notifications for approval requests and terminal task states.
# CONTROL_API_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/[REDACTED]
