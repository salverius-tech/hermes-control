# Local development example. Use deploy/control-api.env.example for systemd deployments.
CONTROL_API_TOKEN=change-me
# Optional: persist task state across API restarts.
# CONTROL_API_DB_PATH=./data/control-api.db
# Optional: execute submitted tasks with a local Hermes command.
# CONTROL_API_HERMES_COMMAND="hermes chat -q"
# Optional: send Discord webhook notifications for task approvals/completions/failures.
# CONTROL_API_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/[REDACTED]
